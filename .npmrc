# React 18 is pinned in package.json, but Next 15's App Router actually runs
# its vendored React 19 in the client bundle — so @react-three/fiber v9 / drei
# v10 (peer react ^19) are the CORRECT runtime match and the peer conflict is
# a false alarm. Without this flag, `npm install` on Vercel fails ERESOLVE.
# Remove when package.json moves to React 19 for real.
legacy-peer-deps=true
